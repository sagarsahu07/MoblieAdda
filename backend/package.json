{
  "name": "mobile-adda-backend",
  "version": "1.0.0",
  "description": "Backend API for Mobile Adda Bhilai",
  "main": "src/index.js",
  "scripts": {
    "start": "nodemon src/index.js",
    "db:generate": "node node_modules/prisma/build/index.js generate",
    "db:push": "node node_modules/prisma/build/index.js db push --skip-generate",
    "db:migrate": "node node_modules/prisma/build/index.js migrate dev",
    "db:studio": "node node_modules/prisma/build/index.js studio",
    "db:seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.10.2",
    "@supabase/supabase-js": "^2.39.7",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.10.2"
  }
}
